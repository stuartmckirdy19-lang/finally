# Required: OpenRouter API key for LLM chat
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data
# If not set, built-in market simulator is used
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (for testing)
LLM_MOCK=false

# Optional: Database file path (default: /app/db/finally.db)
# DB_PATH=/app/db/finally.db
